# IBM Champion Activity Report - personal identity (SAMPLE)
#
# Copy this file to ".env" in the same folder and replace the placeholders with
# your real values. The real ".env" is gitignored and stays private; this sample
# is committed and must contain ONLY placeholder values.
#
# Champion Program ID: the numeric ID issued when you applied to the program.

CHAMPION_PROGRAM_ID=20240000
FIRST_NAME=Jane
LAST_NAME=Doe
PRIMARY_EMAIL=jane.doe@example.com
ALTERNATE_EMAIL=jane@example.org
